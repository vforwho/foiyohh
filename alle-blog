    <script>document.addEventListener("DOMContentLoaded", () => {
    
    // 1. SCROLL MOTION EFFECT (Intersection Observer)
    // Membuat elemen slide-up saat di-scroll ke area viewport
    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
    };

    const motionObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target); // Animasi dijalankan 1 kali saja
            }
        });
    }, observerOptions);

    const motionElements = document.querySelectorAll('.motion-effect');
    motionElements.forEach(el => motionObserver.observe(el));

    // 2. FAQ ACCORDION LOGIC
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
        const question = item.querySelector('.faq-q');
        const answer = item.querySelector('.faq-a');
        const icon = question.querySelector('span');

        question.addEventListener('click', () => {
            const isActive = answer.classList.contains('active');
            
            // Opsional: Menutup semua FAQ yang sedang terbuka
            document.querySelectorAll('.faq-a').forEach(a => a.classList.remove('active'));
            document.querySelectorAll('.faq-q span').forEach(i => i.textContent = '+');

            if (!isActive) {
                answer.classList.add('active');
                icon.textContent = '-';
            }
        });
    });

    // 3. PRODUCT IMAGE GALLERY
    // Dibuat global scope agar bisa diakses oleh atribut onclick pada HTML
    window.changeImage = function(element) {
        // Ambil URL gambar dari thumbnail yang diklik
        const newSrc = element.src;
        // Ganti gambar utama
        document.getElementById('featured-image').src = newSrc;
        
        // Hapus kelas active dari semua thumbnail
        document.querySelectorAll('.thumb').forEach(thumb => {
            thumb.classList.remove('active');
        });
        // Tambahkan kelas active ke thumbnail yang diklik
        element.classList.add('active');
    };

    // 4. MODEL SELECTOR INTERACTION
    const modelBoxes = document.querySelectorAll('.model-box');
    modelBoxes.forEach(box => {
        box.addEventListener('click', () => {
            modelBoxes.forEach(b => b.classList.remove('active'));
            box.classList.add('active');
            // Logika pergantian harga bisa ditambahkan di sini
        });
    });

    // 5. MOBILE MENU TOGGLE
    // Menampilkan navigasi mega menu saat tombol hamburger di header ditekan pada mode mobile
    const mobileBtn = document.querySelector('.mobile-menu-btn');
    const categoryNav = document.querySelector('.category-nav');
    const megaMenuDropdown = document.querySelector('.mega-menu');
    const allCatBtn = document.querySelector('.all-cat-btn');

    if (mobileBtn && categoryNav) {
        mobileBtn.addEventListener('click', () => {
            if(categoryNav.style.display === 'block') {
                categoryNav.style.display = 'none';
            } else {
                categoryNav.style.display = 'block';
            }
        });
    }

    // Toggle dropdown mega menu di mobile
    if(allCatBtn && window.innerWidth <= 768) {
        allCatBtn.addEventListener('click', (e) => {
            e.preventDefault();
            if(megaMenuDropdown.style.display === 'block') {
                megaMenuDropdown.style.display = 'none';
            } else {
                megaMenuDropdown.style.display = 'block';
            }
        });
    }
});</script>
