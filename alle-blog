            function getLineCountWithoutMargin(selector) {
                const element = document.querySelector(selector);

                if (!element) {
                    console.error("Element not found for selector:", selector);
                    return 0;
                }

                // Save the original margin value to restore later
                const originalStyles = [];
                element.querySelectorAll("p, ul, li, h1, h2, h3, h4, h5, h6, span, div").forEach((child) => {
                    originalStyles.push({
                        element: child,
                        margin: child.style.margin,
                    });
                    // Set margin to 0 temporarily
                    child.style.margin = "0";
                });

                // Count total lines
                const lineHeight = parseFloat(window.getComputedStyle(element).lineHeight);
                const elementHeight = element.scrollHeight;
                const lineCount = Math.ceil(elementHeight / lineHeight);

                // Restore original margin
                originalStyles.forEach(({ element, margin }) => {
                    element.style.margin = margin;
                });

                return lineCount;
            }

            const descWrapper = $('#descValue');
